	column name_product
		dataType: string
		lineageTag: 18405666-06f7-4113-a018-e5c41fb63226
		summarizeBy: none
		sourceColumn: name_product

		annotation SummarizationSetBy = Automatic

	column prod_eco =
			
			SWITCH(
			    TRUE(),
			    [fk_category] IN {10, 14, 17, 20, 22, 8}, "eco-friendly",
			    "prod_normal"
			)
		lineageTag: e2dcc8d5-1bab-436b-8292-76f2d93cb324
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition dim_product = m
		mode: import
		source =
				let
				    Source = Sql.Databases("hedire\MSSQLSERVER05"),
				    dw_pi = Source{[Name="dw_pi"]}[Data],
				    dbo_dim_product = dw_pi{[Schema="dbo",Item="dim_product"]}[Data]
				in
				    dbo_dim_product

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

