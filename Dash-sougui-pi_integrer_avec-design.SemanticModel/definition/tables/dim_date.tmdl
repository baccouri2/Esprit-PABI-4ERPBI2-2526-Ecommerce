table dim_date
	lineageTag: 0fba1aa0-677c-48b7-bc7f-6b9df0cb20ce

	measure today = TODAY()
		formatString: General Date
		lineageTag: 6ece90bd-88dd-4351-8e04-9c4107ab7134

	measure 'Revenue YoY %' =
			
			VAR PrevRevenue =
			    CALCULATE(
			        [CA],
			        SAMEPERIODLASTYEAR(dim_date[full_date])
			    )
			RETURN
			DIVIDE([CA] - PrevRevenue, PrevRevenue)
		lineageTag: 2ab84d9b-e511-49df-a4a1-c16f7c7ac681

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column pk_id_date
		dataType: int64
		formatString: 0
		lineageTag: 3d045351-71b6-4b39-b72a-5761e8d61732
		summarizeBy: none
		sourceColumn: pk_id_date

		annotation SummarizationSetBy = Automatic

	column full_date
		dataType: dateTime
		formatString: General Date
		lineageTag: 55ef50f8-e3ef-45a5-ac4c-8dd1e42e4937
		summarizeBy: none
		sourceColumn: full_date

		variation Variation
			isDefault
			relationship: 0d9bf3de-25d8-4059-8ba0-c70a4557053e
			defaultHierarchy: LocalDateTable_9cbb6752-fb1f-4920-b39f-b44a2aafbb2c.'Hiérarchie de dates'

		annotation SummarizationSetBy = Automatic

	column day
		dataType: int64
		formatString: 0
