		summarizeBy: sum
		sourceColumn: day

		annotation SummarizationSetBy = Automatic

	column month
		dataType: int64
		formatString: 0
		lineageTag: 8e908cda-c48d-4e58-b256-8a01c214f68a
		summarizeBy: sum
		sourceColumn: month

		annotation SummarizationSetBy = Automatic

	column trimester
		dataType: int64
		formatString: 0
		lineageTag: ab0259aa-508d-4b7a-a7cc-614ad5ddd999
		summarizeBy: sum
		sourceColumn: trimester

		annotation SummarizationSetBy = Automatic

	column semester
		dataType: int64
		formatString: 0
		lineageTag: 6dec9510-e9aa-4c9d-bf13-fe2b15c6380e
		summarizeBy: sum
		sourceColumn: semester

		annotation SummarizationSetBy = Automatic

	column year
		dataType: int64
		formatString: 0
		lineageTag: 279a1408-cfc2-4174-a849-ff9bb71bc417
		summarizeBy: none
		sourceColumn: year

		annotation SummarizationSetBy = User

	column Mois =
			
			SWITCH(
			    MONTH('dim_date'[full_date]),
			    1, "January",
			    2, "February",
			    3, "March",
			    4, "April",
			    5, "May",
			    6, "June",
			    7, "July",
			    8, "August",
			    9, "September",
			    10, "October",
			    11, "November",
			    12, "December",
			    "Unknown"
			)
		lineageTag: 84732d55-bf18-434f-8cea-71a903e4535f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition dim_date = m
		mode: import
		source =
				let
				    Source = Sql.Database("hedire\MSSQLSERVER05", "dw_pi"),
				    dbo_dim_date = Source{[Schema="dbo",Item="dim_date"]}[Data],
				    #"Type modifié" = Table.TransformColumnTypes(dbo_dim_date,{{"day", Int64.Type}, {"month", Int64.Type}, {"trimester", Int64.Type}, {"semester", Int64.Type}, {"year", Int64.Type}})
				in
