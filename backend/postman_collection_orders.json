            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id_order\": \"14148\",\n  \"order_status\": \"Confirmée\",\n  \"date_commande\": \"2026-01-02\",\n  \"fk_delivery\": 385\n}"
