      }
    },
    {
      "name": "2. List All Orders",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/orders",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "orders"]
        },
        "description": "Liste toutes les commandes (458 commandes)"
      }
    },
    {
      "name": "3. Search Orders",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/orders?q=14148",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "orders"],
          "query": [
            {
              "key": "q",
              "value": "14148",
              "description": "Recherche par id_order, num_bl ou company"
            }
          ]
        },
        "description": "Recherche des commandes par mot-clé"
      }
    },
    {
