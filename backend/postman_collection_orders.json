          "query": [
            {
              "key": "status",
              "value": "En cours",
              "description": "Filtre par statut"
            }
          ]
        },
        "description": "Filtre les commandes par statut"
      }
    },
    {
      "name": "5. Get Order Details",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/api/orders/917",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["api", "orders", "917"]
        },
        "description": "Récupère les détails d'une commande spécifique avec les articles"
      }
    },
    {
